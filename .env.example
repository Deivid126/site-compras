# ─────────────────────────────────────────────────────────────
# Variaveis de ambiente
# Copie para .env e ajuste. NUNCA commite valores reais de .env.
# ─────────────────────────────────────────────────────────────

# URL do banco Postgres (local usa localhost; na Vercel use a connection string
# do Vercel Postgres ou de um provedor externo como Neon/Supabase).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/presentes?schema=public"

# URL publica do site (usada para SEO/OG/sitemap). Na Vercel defina como a URL
# de producao, ex.: https://seu-projeto.vercel.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"