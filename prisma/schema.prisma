generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Item {
  id          Int        @id @default(autoincrement())
  title       String     @unique
  description String?
  priceCents  Int
  imageUrl    String
  storeUrl    String
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  purchases   Purchase[]
}

model Purchase {
  id         Int      @id @default(autoincrement())
  itemId     Int      @unique
  item       Item     @relation(fields: [itemId], references: [id])
  visitorId  String
  buyerName  String
  createdAt  DateTime @default(now())

  @@index([visitorId])
}
